{
  "name": "goaly",
  "version": "0.1.1",
  "description": "Harness-agnostic goal-orchestration layer: run a coding agent until a frozen success criterion is verifiably met.",
  "type": "module",
  "license": "MIT",
  "author": "krimvp",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/krimvp/goaly.git"
  },
  "homepage": "https://github.com/krimvp/goaly#readme",
  "bugs": {
    "url": "https://github.com/krimvp/goaly/issues"
  },
  "engines": {
    "node": ">=20"
  },
  "bin": {
    "goaly": "dist/goaly.js"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "dev": "tsx src/cli/bin.ts",
    "build": "node scripts/build.mjs && tsc -p tsconfig.build.json",
    "start": "node dist/goaly.js",
    "clean": "rm -rf dist coverage *.tgz",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "coverage": "vitest run --coverage",
    "prepare": "npm run build"
  },
  "dependencies": {
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/node": "^22.10.5",
    "@vitest/coverage-v8": "^2.1.8",
    "esbuild": "^0.24.2",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3",
    "vitest": "^2.1.8"
  }
}
